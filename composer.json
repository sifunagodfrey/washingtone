{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "neptunesmovers/neptunesmovers",
    "type": "project",
    "description": "Neptunes Movers and Relocators is a reputable moving company that provides comprehensive moving services to individuals and businesses. With a team of experienced professionals, Neptunes Movers and Relocators offers efficient and reliable moving solutions, ensuring a smooth transition for their clients. Whether it's local or long-distance moves, they prioritize customer satisfaction and strive to make the moving process as stress-free as possible.",
    "keywords": ["laravel", "cms", "bootcamp"],
    "license": "MIT",

    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10",
        "phpmailer/phpmailer": "^7.0"
    },

    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6"
    },

    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helpers.php",
            "app/Helpers/upload.php",
            "app/Helpers/response.php"
        ]
    },

    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },

    "scripts": {

        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],

        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],

        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],

        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },

    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },

    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true
}
